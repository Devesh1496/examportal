# ─── ExamPortal Backend Environment ───────────────────────────
# Copy this file to .env and fill in your values

# OpenRouter API Key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-key-here

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
# Uncomment to use Gemini directly instead of OpenRouter
# GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI Configurations (use gcloud auth application-default login)
# VERTEX_PROJECT_ID=your-google-cloud-project-id
# VERTEX_LOCATION=us-central1
# VERTEX_MODEL=gemini-1.5-flash

# OpenRouter Model (optional, defaults to google/gemini-2.5-flash)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Server port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
